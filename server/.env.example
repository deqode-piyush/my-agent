# Required: get a key at https://platform.openai.com/api-keys
OLLAMA_API_KEY=....

# Optional overrides
OLLAMA_MODEL=qwen3.5:4b
OLLAMA_EMBED_MODEL=nomic-embed-text:latest
PORT=4000

# Pinecone Vector Database API Key
PINECONE_API_KEY=....
# Auth (required — server refuses to start without these)
JWT_ACCESS_SECRET=....
JWT_REFRESH_SECRET=....
CLIENT_ORIGIN=...
NODE_ENV=....

# Postgres DB Setup
DATABASE_URL=...

# Firecrawl API Key
FIRECRAWL_API_KEY=....

# Google Safe Browsing API Key
GOOGLE_SAFE_BROWSING_API_KEY=...
